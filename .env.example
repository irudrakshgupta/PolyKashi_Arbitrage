# Copy this file to .env and fill in your own values.
# .env is git-ignored and never committed.

# ── Polymarket ────────────────────────────────────────────────────────────────
# Your Polygon wallet private key (hex, with 0x prefix)
POLY_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY_HERE
# Corresponding public address
POLY_ADDRESS=0xYOUR_POLYGON_ADDRESS_HERE

# ── Kalshi ────────────────────────────────────────────────────────────────────
# From https://kalshi.com/account/api-keys (RSA key type)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ── Execution settings ────────────────────────────────────────────────────────
# Set to 'true' only after you have tested with dry-run and understand the risks
AUTO_EXECUTE=false
# Maximum dollars to deploy per arb leg
MAX_POSITION_USDC=50
# Minimum net edge required AFTER all fees and slippage (2% default)
MIN_NET_EDGE_PCT=0.02
